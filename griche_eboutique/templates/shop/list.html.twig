{% extends 'base.html.twig' %}
{% block title %}{{ pageTitle }}{% endblock %}

{% block body %}
  <section class="hero">
    <h1>{{ pageTitle }}</h1>
    <p>&nbsp;</p>
  </section>

  <div class="grid">
    {% for p in products %}
      <div class="card">
        <div class="product">
          {% if p.imagePath %}
            <img class="pimg" src="{{ p.imagePath }}" alt="{{ p.name }}">
          {% endif %}
          <div class="title">{{ p.name }}</div>
          <div class="muted" style="text-align:center">{{ (p.priceCents / 100)|number_format(2, '.', ' ') }} €</div>
          <form method="post" action="{{ path('cart_add', {id: p.id}) }}">
            <input type="hidden" name="qty" value="1" />
            <button class="btn" type="submit">Ajouter au panier</button>
          </form>
          <a class="pill" style="justify-content:center" href="{{ path('shop_product', {slug: p.slug}) }}">Détails</a>
        </div>
      </div>
    {% else %}
      <p class="muted">Aucun produit.</p>
    {% endfor %}
  </div>
{% endblock %}
