{% extends 'base.html.twig' %}
{% block title %}Panier{% endblock %}

{% block body %}
  <section class="hero">
    <h1>Panier</h1>
    <p>Modifie les quantités puis valide la commande.</p>
  </section>

  <div class="card">
    <div style="padding:16px">
      {% if cart.lines|length == 0 %}
        <p class="muted">Panier vide.</p>
      {% else %}
        <form method="post" action="{{ path('cart_update') }}">
          <table class="table">
            <thead>
              <tr>
                <th>Produit</th>
                <th class="right">PU</th>
                <th class="right">Qté</th>
                <th class="right">Montant</th>
              </tr>
            </thead>
            <tbody>
              {% for line in cart.lines %}
                <tr>
                  <td>{{ line.product.name }}</td>
                  <td class="right">{{ (line.unitCents / 100)|number_format(2, '.', ' ') }} €</td>
                  <td class="right">
                    <input class="input" style="width:90px; text-align:right" type="number" min="0" name="items[{{ line.product.id }}]" value="{{ line.qty }}" />
                  </td>
                  <td class="right">{{ (line.lineCents / 100)|number_format(2, '.', ' ') }} €</td>
                </tr>
              {% endfor %}
            </tbody>
            <tfoot>
              <tr>
                <th colspan="3" class="right">Sous-total</th>
                <th class="right">{{ (cart.subtotalCents / 100)|number_format(2, '.', ' ') }} €</th>
              </tr>
              <tr>
                <th colspan="3" class="right">Transport</th>
                <th class="right">{{ (cart.shippingCents / 100)|number_format(2, '.', ' ') }} €</th>
              </tr>
              <tr>
                <th colspan="3" class="right">Total</th>
                <th class="right">{{ (cart.totalCents / 100)|number_format(2, '.', ' ') }} €</th>
              </tr>
            </tfoot>
          </table>
          <div style="display:flex; gap:10px; flex-wrap:wrap; margin-top:12px">
            <button class="btn" type="submit">Mettre à jour</button>
            <a class="pill" href="{{ path('checkout_index') }}">Commander</a>
          </div>
        </form>

        <form method="post" action="{{ path('cart_clear') }}" style="margin-top:10px">
          <button class="btn" type="submit">Vider</button>
        </form>
      {% endif %}
    </div>
  </div>
{% endblock %}

