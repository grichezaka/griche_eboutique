{% extends 'base.html.twig' %}
{% block title %}Connexion{% endblock %}

{% block body %}
  <div class="auth-wrap">
    <div class="card auth-card">
      {% if error %}
        <div class="flash error">Identifiants invalides.</div>
      {% endif %}

      <div class="auth-head">
        <h1 class="auth-title">Connexion</h1>
        <p class="auth-sub">Connecte-toi pour finaliser ta commande.</p>
      </div>

      <form method="post" class="auth-form">
        <div class="form-row">
          <label for="login_email">Email</label>
          <input class="input" id="login_email" type="email" name="_username" value="{{ last_username }}" autocomplete="email" required />
        </div>
        <div class="form-row">
          <label for="login_password">Mot de passe</label>
          <input class="input" id="login_password" type="password" name="_password" autocomplete="current-password" required />
        </div>
        <input type="hidden" name="_csrf_token" value="{{ csrf_token('authenticate') }}">
        <div class="auth-actions">
          <button class="btn" type="submit">Se connecter</button>
          <a class="pill" href="{{ path('app_register') }}">Créer un compte</a>
        </div>
      </form>
    </div>
  </div>
{% endblock %}
